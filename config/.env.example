# .env.example - Development Configuration Reference

# ============ Core Environment ============
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
RUNNING_IN_DOCKER=false

# ============ Server Configuration ============
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============ Database Configuration ============
# DB_PASSWORD: loaded from config/.env.compose via compose_env.py — do NOT set here.
# Local dev: docker compose --env-file config/.env.compose up -d postgres
RUNNING_IN_DOCKER=false
DB_PLATFORM_ENGINE_REQUIRED=true
DB_USER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=vita_db

# Database Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ============ Redis Configuration ============
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# ============ LLM Services - Unified Naming (v10.0.0) ============
# Local Development URLs (127.0.0.1)
# Pipeline roles: MAIN=soul, REVISE=revise, LOGIC=logic, MEMORY=embedding, EMOBLOOM=emotion
MAIN_LLM_URL=http://127.0.0.1:8081
REVISE_LLM_URL=http://127.0.0.1:8082
LOGIC_LLM_URL=http://127.0.0.1:8083
MEMORY_LLM_URL=http://127.0.0.1:8084
EMOBLOOM_LLM_URL=http://127.0.0.1:8085

# LLM Model Names (REVISE_LLM_MODEL backs ReviseEngine on port 8082)
MAIN_LLM_MODEL=Mistral-Nemo-12B
REVISE_LLM_MODEL=Llama-3.2-3B
LOGIC_LLM_MODEL=Distil-NPC-gemma-3-1b
MEMORY_LLM_MODEL=bge-m3
EMOBLOOM_LLM_MODEL=Emobloom-7b

# LLM Timeouts (Seconds)
MAIN_LLM_TIMEOUT=120
REVISE_LLM_TIMEOUT=30
LOGIC_LLM_TIMEOUT=30
MEMORY_LLM_TIMEOUT=20
EMOBLOOM_LLM_TIMEOUT=10

# LLM Retry Policy
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=1

# ============ Security ============
JWT_SECRET=dev_jwt_secret_change_in_production_minimum_32_chars
ENCRYPT_KEY=dev_encrypt_key_change_in_production_minimum_32_chars
SECRET_KEY=dev_secret_key_change_in_production_minimum_32_chars
API_KEY=dev_api_key_change_in_production_minimum_32_chars
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30
AUTH_ENABLED=true

# ============ CORS ============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============ Monitoring ============
VICTORIA_METRICS_URL=http://127.0.0.1:8428
VICTORIA_LOGS_URL=http://127.0.0.1:9428
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_VICTORIA_LOGS_SHIPPER=true
VICTORIA_LOGS_SERVICE=vita-api

# ============ Clinical Risk ============
RISK_ESCALATION_THRESHOLD=4
WALKER_SCORE_THRESHOLD=0.3
CONCERN_THRESHOLD=0.6
HIGH_RISK_SESSION_THRESHOLD=10
SESSION_TIMEOUT_MINUTES=30
SESSION_MAX_RETENTION_DAYS=90
AUTO_ESCALATION_DELAY_MINUTES=1
ESCALATION_CONFIRMATION_TIMEOUT=30

# ============ Rate Limiting ============
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# ============ Testing ============
USE_MOCK_LLM=false
USE_MOCK_EMOTION=false

# ============ Hardware Profile (RTX 4070 Ti SUPER + 192GB RAM) ============
# See config/hardware_profile.json for full service GPU/CPU allocation.
# Reserve 20% VRAM (~3.2GB) for future TTS + VTube Studio.
VRAM_TOTAL_MB=16384
VRAM_RESERVE_PERCENT=20
MAIN_LLM_GPU_LAYERS=40
AUX_LLM_GPU_LAYERS=0

# ============ Phase 2: LLM probe / Star timeouts ============
LLM_PROBE_TIMEOUT=2.0
STAR_ORCHESTRATION_TIMEOUT=90
STAR_ORCHESTRATION_TIMEOUT_DEGRADED=35

# ============ Phase 3: v9 Pipeline ============
V9_PIPELINE_ENABLED=true
LLAMA_AUDIT_ENABLED=true
LLAMA_AUDIT_RISK_THRESHOLD=3
LLAMA_AUDIT_QUALITY_THRESHOLD=0.7
V9_PERSONALITY_ENABLED=true
V9_MIN_RESPONSE_LENGTH=10
V9_NEMO_REGEN_ON_LOW_QUALITY=true
V9_NEMO_REGEN_MAX=1
META_LAYER_PERSIST=true

# Phase 5: Cognitive Layer (User Shadow + Milestones + 24-dim emotion)
COGNITIVE_LAYER_ENABLED=true
EMOTION_DIMENSIONS=24
USER_SHADOW_BLEND=0.35

# Phase 6: Seele Meta Controller (on-demand 8082/8083 via host Seele)
SEELE_META_CONTROLLER_ENABLED=true
SEELE_META_CONTROLLER_URL=http://127.0.0.1:8090
SEELE_META_PORT=8090
SEELE_ON_DEMAND_IDLE_SEC=300
SEELE_ON_DEMAND_START_TIMEOUT=120
# Set SEELE_DEPLOY_ALL=true to start all LLMs at Seele boot (legacy mode)

# KAG Reality Layer (verifiable fact grounding)
KAG_REALITY_ENABLED=true
KAG_MAX_FACTS=12