# config/.env.compose.example
# Copy to config/.env.compose (gitignored) for local Docker Compose and compose_env.py.
#
#   cp config/.env.compose.example config/.env.compose   (Linux/macOS)
#   Copy-Item config/.env.compose.example config/.env.compose   (Windows)
#
# NEVER commit config/.env.compose. Production/staging values live in GitHub
# Encrypted Secrets and are materialized at deploy time (see scripts/deploy/).

# --- PostgreSQL (Platform Engine) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_compose_password
POSTGRES_DB=vita_db
# Host port published for local tools (app on host uses DB_PORT=5433 in .env.local).
POSTGRES_HOST_PORT=5433

DB_USER=postgres
DB_PASSWORD=change_me_compose_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vita_db
DATABASE_URL=postgresql+psycopg2://postgres:change_me_compose_password@postgres:5432/vita_db

# --- Observability / automation (dev placeholders) ---
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_admin
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_min_32_chars

# --- vita-api application secrets (Docker production profile) ---
JWT_SECRET=change_me_jwt_secret_minimum_32_characters
ENCRYPT_KEY=change_me_encrypt_key_minimum_32_characters
SECRET_KEY=change_me_secret_key_minimum_32_characters
API_KEY=change_me_api_key_minimum_32_characters
