# .gitignore

# 環境變數（永不提交含真實密鑰的檔案）
.env
.env.local
.env.*.local
config/.env
config/.env.compose
!.env.example
!config/.env.example
!config/.env.compose.example
!config/.env.compose.ci

# 金鑰與憑證
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
*.crt
secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.engine7b/

# Large vendored / runtime artifacts
llama-cpp-python/
models/
cache/
data/
# Keep Seele personality canon / profile under version control
!PersonalityModule/data/
!PersonalityModule/data/*.json
Gemma/
dict/
build/
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Database
*.db
*.sqlite
*.sqlite3

# Testing
.pytest_cache/
.coverage
htmlcov/

# Redis dump
dump.rdb

# Node modules（前端）
node_modules/